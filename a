<!doctype html>
<html lang="vi">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>🧧 Lì xì đầu năm</title>

<style>
body{
font-family:system-ui,Arial;
margin:0;
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
background:#f5f5f5;
}

.card{
background:white;
border-radius:16px;
padding:24px;
width:360px;
text-align:center;
box-shadow:0 10px 30px rgba(0,0,0,0.1);
}

h1{
margin:0 0 6px;
font-size:22px;
}

.subtitle{
font-size:14px;
color:#666;
margin-bottom:16px;
}

.envelope{
width:240px;
height:300px;
margin:auto;
border-radius:18px;
background:linear-gradient(#ef4444,#b91c1c);
position:relative;
display:flex;
align-items:center;
justify-content:center;
overflow:hidden;
}

.seal{
position:absolute;
top:65%;
left:50%;
transform:translate(-50%,-50%);
background:gold;
border-radius:50%;
width:90px;
height:90px;
display:flex;
align-items:center;
justify-content:center;
font-weight:bold;
}

.open .seal{
opacity:0;
}

.amount{
font-size:40px;
color:white;
font-weight:bold;
z-index:3;
}

.btn{
margin-top:16px;
width:100%;
padding:12px;
border:none;
border-radius:12px;
background:#ef4444;
color:white;
font-size:16px;
cursor:pointer;
}

.btn.secondary{
background:#111827;
}

.status{
margin-top:10px;
font-size:13px;
color:#16a34a;
}
</style>
</head>

<body>

<div class="card">

<h1>🧧 Lì xì đầu năm</h1>
<div class="subtitle">
Random từ 1.000 → 500.000 VND
</div>

<div id="envelope" class="envelope">
<div id="amount" class="amount">?</div>
<div class="seal">LÌ XÌ</div>
</div>

<button id="openBtn" class="btn">Mở bao lì xì</button>
<button id="copyBtn" class="btn secondary" disabled>Copy số tiền</button>

<div id="status" class="status"></div>

</div>

<script>

const KEY="lixi_once";
const MIN=1000;
const MAX=500000;
const STEP=1000;

const openBtn=document.getElementById("openBtn");
const copyBtn=document.getElementById("copyBtn");
const amountEl=document.getElementById("amount");
const env=document.getElementById("envelope");
const status=document.getElementById("status");

const params=new URLSearchParams(location.search);
const admin=params.get("admin")==="1";

function rand(){
let steps=(MAX-MIN)/STEP+1;
return MIN+Math.floor(Math.random()*steps)*STEP;
}

function format(n){
return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g,".");
}

function openEnvelope(){

if(!admin && localStorage.getItem(KEY)) return;

let v=rand();
amountEl.textContent=format(v);
env.classList.add("open");

copyBtn.disabled=false;
status.textContent="Chúc mừng năm mới!";

if(!admin){
localStorage.setItem(KEY,v);
openBtn.disabled=true;
}

}

openBtn.onclick=openEnvelope;

copyBtn.onclick=()=>{
let v=amountEl.textContent.replaceAll(".","");
navigator.clipboard.writeText(v);
status.textContent="Đã copy số tiền";
};

if(!admin && localStorage.getItem(KEY)){
let v=localStorage.getItem(KEY);
amountEl.textContent=format(v);
env.classList.add("open");
openBtn.disabled=true;
copyBtn.disabled=false;
status.textContent="Bạn đã mở rồi";
}

</script>

</body>
</html>
